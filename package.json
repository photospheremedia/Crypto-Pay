{
  "name": "crypto-pay",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @crypto-pay/portal build",
    "dev:storefront": "pnpm --filter @crypto-pay/storefront dev --port 3000",
    "dev:portal": "pnpm --filter @crypto-pay/portal dev --port 3001",
    "build:storefront": "pnpm --filter @crypto-pay/storefront build",
    "build:portal": "pnpm --filter @crypto-pay/portal build",
    "test": "pnpm --filter @crypto-pay/portal test",
    "test:ui": "pnpm --filter @crypto-pay/portal test:ui",
    "test:headed": "pnpm --filter @crypto-pay/portal test:headed",
    "db:types": "supabase gen types typescript --project-id hwntncyiqaltzvlidscg > apps/portal/lib/database.types.ts",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --use-migra -f",
    "db:reset": "supabase db reset",
    "vercel:deploy": "vercel --prod",
    "vercel:preview": "vercel",
    "vercel:env": "vercel env pull",
    "vercel:link": "vercel link --project crypto-pay-portal",
    "vercel:env:push": "powershell -ExecutionPolicy Bypass -File scripts/sync-vercel-env.ps1",
    "vercel:logs": "vercel logs",
    "vercel:inspect": "vercel inspect",
    "check:env": "./scripts/check-env.sh"
  },
  "devDependencies": {
    "next": "16.1.6",
    "vercel": "^50.9.6"
  }
}
