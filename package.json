{
  "name": "crypto-pay",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @crypto-pay/portal build",
    "dev:portal": "pnpm --filter @crypto-pay/portal dev --port 3001",
    "dev:portal:clean": "bash scripts/kill-port.sh 3001 && bash scripts/clean-portal-next.sh && pnpm dev:portal",
    "dev:setup": "pnpm --filter @crypto-pay/portal dev:setup",
    "build:portal": "pnpm --filter @crypto-pay/portal build",
    "typecheck:portal": "pnpm --filter @crypto-pay/portal typecheck",
    "test": "pnpm --filter @crypto-pay/portal test",
    "test:ui": "pnpm --filter @crypto-pay/portal test:ui",
    "test:headed": "pnpm --filter @crypto-pay/portal test:headed",
    "playwright:connect": "pnpm --filter @crypto-pay/portal playwright:connect",
    "playwright:connect:login": "pnpm --filter @crypto-pay/portal playwright:connect:login",
    "playwright:connect:merchant": "pnpm --filter @crypto-pay/portal playwright:connect:merchant",
    "playwright:login": "pnpm --filter @crypto-pay/portal playwright:login",
    "db:types": "supabase gen types typescript --linked > apps/portal/lib/database.types.ts",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --use-migra -f",
    "db:reset": "supabase db reset",
    "porkbun:secrets": "./scripts/setup-porkbun-github-secrets.sh",
    "porkbun:ping": "./scripts/porkbun-api.sh ping",
    "porkbun:domains": "./scripts/porkbun-api.sh domains",
    "porkbun:dns": "./scripts/porkbun-api.sh dns",
    "dns:plan": "python3 scripts/porkbun-dns-vercel.py",
    "dns:apply": "python3 scripts/porkbun-dns-vercel.py --apply",
    "dns:clean": "python3 scripts/porkbun-dns-vercel.py --clean",
    "vercel:login": "pnpm exec vercel login",
    "vercel:auth-photosphere": "./scripts/vercel-auth-photosphere.sh",
    "vercel:link": "./scripts/vercel-auth-photosphere.sh --link",
    "vercel:env-sync": "./scripts/sync-vercel-env.sh",
    "vercel:secrets": "./scripts/setup-vercel-github-secrets.sh",
    "vercel:deploy": "pnpm exec vercel deploy --prod",
    "vercel:preview": "pnpm exec vercel deploy",
    "vercel:setup": "./scripts/setup-vercel-photospheremedia.sh",
    "check:env": "./scripts/check-env.sh",
    "supabase:status": "./scripts/supabase-auth.sh status",
    "supabase:login": "./scripts/supabase-auth.sh login",
    "supabase:handoff": "./scripts/supabase-auth.sh handoff",
    "supabase:projects": "./scripts/supabase-auth.sh projects",
    "supabase:logout": "./scripts/supabase-auth.sh logout",
    "supabase:open": "./scripts/supabase-auth.sh open",
    "supabase:connect": "./scripts/connect-photospheremedia.sh",
    "supabase:backup:status": "./scripts/supabase-backup-status.sh",
    "supabase:backup:enable": "./scripts/supabase-enable-platform-backups.sh",
    "supabase:db:dump": "./scripts/supabase-db-dump.sh",
    "supabase:secrets": "./scripts/setup-supabase-github-secrets.sh",
    "supabase:migration:repair-drift": "./scripts/repair-supabase-migration-history.sh",
    "portal:secrets": "./scripts/setup-portal-github-secrets.sh",
    "resend:sync": "./scripts/setup-resend-secrets.sh",
    "resend:verify": "./scripts/verify-supabase-resend-config.sh && cd apps/portal && pnpm email:verify"
  },
  "devDependencies": {
    "vercel": "^50.9.6"
  }
}
