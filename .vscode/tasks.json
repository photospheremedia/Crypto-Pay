{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Dev: Portal (Next.js)",
      "type": "shell",
      "command": "bash scripts/kill-port.sh 3001 && pnpm dev:portal",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Ready in|Local:\\s+http://localhost:3001)"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "🧹 Dev: Portal (clean .next)",
      "type": "shell",
      "command": "pnpm dev:portal:clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Ready in|Local:\\s+http://localhost:3001)"
        }
      },
      "group": "build"
    },
    {
      "label": "👤 Dev: Setup local user",
      "type": "shell",
      "command": "pnpm dev:setup",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "🏗️ Build: Portal",
      "type": "shell",
      "command": "pnpm build:portal",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "📦 Install Dependencies",
      "type": "shell",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "🧪 Test: All",
      "type": "shell",
      "command": "pnpm test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "test"
    },
    {
      "label": "🔄 DB: Regenerate Types",
      "type": "shell",
      "command": "pnpm db:types",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "🔄 DB: Push Migrations",
      "type": "shell",
      "command": "pnpm db:push",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "🌐 Type Check: Portal",
      "type": "shell",
      "command": "pnpm typecheck:portal",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": ["$tsc"],
      "group": "build"
    }
  ]
}
