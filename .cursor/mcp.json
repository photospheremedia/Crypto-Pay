  "mcpServers": {
    "supabase": {
      "command": "bash",
      "args": ["scripts/mcp-supabase.sh"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "cwd": "apps/portal"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
