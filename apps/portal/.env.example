# Crypto Pay — PhotoSphere production (usbxwewohpsbjwiuazpf)
# Full env + API guide: docs/ENV_AND_API_GUIDE.md
# Infra sync: docs/PLATFORM_CONFIGURATION.md
# Dashboard: https://supabase.com/dashboard/project/usbxwewohpsbjwiuazpf/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://usbxwewohpsbjwiuazpf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=__PASTE_FROM_SUPABASE_DASHBOARD__

# SERVER ONLY (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=__PASTE_HERE__

# Supabase Edge Functions
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://usbxwewohpsbjwiuazpf.supabase.co/functions/v1

# Runner app (settlement worker) — create via: pnpm exec tsx scripts/create-runner-api-client.ts
# RUNNER_API_KEY=cpk_...
# RUNNER_API_SECRET=cps_...

# Cloudflare Turnstile (disabled in app for now — set isTurnstileEnabled in turnstile-config.ts)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=__PASTE_HERE__
# TURNSTILE_SECRET_KEY → Supabase Edge Function secret when re-enabled

# Rate limiting (Upstash Redis) — set as Supabase Edge Function secrets for rate-limit-check:
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
# Without Redis, limits are not enforced (requests are allowed).

# Resend (Email Service) — see docs/EMAIL_SETUP_CRYPTO_PAY.md
RESEND_API_KEY=__PASTE_HERE__
EMAIL_FROM=Crypto Pay <noreply@cryptopay.sale>
# Merchant "Reply" in inbox — use a monitored support inbox (avoid personal addresses)
EMAIL_REPLY_TO=support@cryptopay.sale
# Internal wallet review — use a private team inbox on your domain (avoid personal addresses)
ADMIN_REVIEW_EMAIL=admin@cryptopay.sale
# Comma-separated staff emails (also receive wallet review requests + can access /admin)
# ADMIN_ALLOWED_EMAILS=admin@cryptopay.sale,other@example.com
# Email images (never use localhost in real sends). Logos live in public/email/ (pnpm email:logo).
# EMAIL_ASSET_ORIGIN=https://cryptopay.sale
# EMAIL_LOGO_URL=https://cryptopay.sale/email/logo.png

# Payments (Skrill)
SKRILL_MERCHANT_EMAIL=__PASTE_HERE__
SKRILL_MERCHANT_ID=__PASTE_HERE__
SKRILL_SECRET_WORD=__PASTE_HERE__
SKRILL_API_BASE_URL=__PASTE_HERE__

# Used to compute redirect URLs (optional)
NEXT_PUBLIC_APP_URL=https://cryptopay.sale

# Public brand social profiles (optional, set only real company profile URLs)
NEXT_PUBLIC_SOCIAL_X_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=

# AI Chat Widget - Use ONE of these (FREE options available!)

# Option 1: Groq (RECOMMENDED - FREE & FAST) ⭐
# Sign up at https://console.groq.com
# Free tier: 14,400 requests/day, lightning-fast Llama 3.3 70B
GROQ_API_KEY=gsk_...

# Option 2: OpenAI (PAID - requires credit card)
# Sign up at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Option 3: No API key? No problem!
# The chat widget works out of the box with rule-based responses
# Just leave both keys empty and you'll still have a working chatbot

# Note: If both keys are set, Groq will be used (it's free!)

# Runner app (settlement / payment processor on separate server)
# Create client: pnpm --filter @crypto-pay/portal exec tsx scripts/create-runner-api-client.ts
# Docs: docs/RUNNER_INTEGRATION.md
# RUNNER_API_KEY=cpk_...
# RUNNER_API_SECRET=cps_...
# RUNNER_API_BASE_URL=https://<project>.supabase.co/functions/v1/runner-api

# Optional: chain watcher automation (internal only, not merchant UI)
# BTC_PROVIDER_API_KEY=__PASTE_HERE__
# BTC_PROVIDER_BASE_URL=https://__PROVIDER_HOST__
# INTERNAL_API_KEY=__PASTE_HERE__
