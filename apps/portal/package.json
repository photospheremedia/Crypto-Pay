{
  "name": "@crypto-pay/portal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "dev:portal": "next dev --turbopack --port 3001",
    "dev:clean": "bash ../../scripts/kill-port.sh 3001 && node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev --turbopack --port 3001",
    "dev:setup": "npx tsx scripts/setup-local-dev-user.ts",
    "dev:reset-merchant": "npx tsx scripts/reset-merchant-user.ts",
    "runner:client": "npx tsx scripts/create-runner-api-client.ts",
    "runner:test": "npx tsx scripts/test-runner-api.ts",
    "email:verify": "npx tsx scripts/verify-resend-config.ts",
    "email:preview": "npx tsx scripts/preview-email-templates.ts",
    "email:sync-auth": "npx tsx scripts/sync-supabase-auth-templates.ts",
    "email:sync-auth:push": "npx tsx scripts/sync-supabase-auth-templates.ts --push",
    "email:test-suite": "npx tsx scripts/send-onboarding-email-suite.ts",
    "email:logo": "npx tsx scripts/generate-email-logo.tsx",
    "prebuild": "pnpm email:logo",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "test": "playwright test --project=chromium",
    "test:ui": "playwright test --ui --project=chromium",
    "test:headed": "playwright test --headed --project=chromium",
    "test:authenticated": "playwright test --project=chromium-authenticated",
    "test:report": "playwright show-report",
    "test:prod": "playwright test -c playwright.prod.config.ts",
    "test:prod:headed": "playwright test -c playwright.prod.config.ts --headed",
    "playwright:login": "playwright test --project=setup",
    "playwright:open": "playwright open http://localhost:3001/account --load-storage=playwright/.auth/user.json",
    "playwright:open:admin": "playwright open http://localhost:3001/admin/dashboard --load-storage=playwright/.auth/user.json",
    "playwright:connect": "npx tsx scripts/playwright-connect-browser.ts",
    "playwright:connect:login": "npx tsx scripts/playwright-connect-browser.ts",
    "playwright:connect:admin": "npx tsx scripts/playwright-connect-browser.ts -- --admin",
    "playwright:connect:merchant": "LOCAL_DEV_ADMIN=0 PLAYWRIGHT_AFTER_LOGIN=/account npx tsx scripts/playwright-connect-browser.ts",
    "playwright:configure-supabase-auth": "npx tsx scripts/configure-supabase-auth-dashboard.ts",
    "supabase:push-auth": "npx tsx scripts/sync-supabase-auth-templates.ts --push --push-auth",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "i18n:sync": "tsx scripts/sync-locale-messages.ts",
    "i18n:marketing": "tsx scripts/apply-marketing-translations.ts"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.19",
    "@ai-sdk/openai": "^3.0.23",
    "@ai-sdk/react": "^3.0.66",
    "@crypto-pay/db": "workspace:*",
    "@crypto-pay/shared": "workspace:*",
    "@gsap/react": "^2.1.2",
    "@marsidev/react-turnstile": "^1.4.1",
    "@radix-ui/react-checkbox": "^1.0.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.0.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@sankyu/react-circle-flags": "^1.6.7",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.2",
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "^25.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "ai": "^6.0.64",
    "autoprefixer": "^10.4.23",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.29.2",
    "gsap": "^3.14.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "baseline-browser-mapping": "^2.9.18",
    "shadcn": "^4.8.0",
    "tsx": "^4.21.0"
  }
}
